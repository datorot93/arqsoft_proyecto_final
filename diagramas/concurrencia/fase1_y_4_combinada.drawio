        <!-- ============ EDGES — SYNC WRITE PATH ============ -->
        <mxCell id="e0" value="HTTPS" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="cli" target="t_borde">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="forward HTTP/gRPC&#10;[síncrono — bloquea]" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="t_borde" target="t_req">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="reservarFondos(...)&#10;[síncrono — bloquea]" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="c_cdtsvc" target="sb_acl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="SOAP&#10;timeout + CB" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="sb_acl" target="ext_core">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="ACID TX:&#10;INSERT cdt + outbox (abrirCDT)&#10;UPDATE WHERE status IN (...) (congelarCDT)" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="c_cdtsvc" target="sb_db">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="180" />
              <mxPoint x="1500" y="180" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e5" value="publish cdt.creado&#10;(idempotente, fire-and-forget)" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF;dashed=1" edge="1" parent="1" source="c_cdtsvc" target="sb_broker">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="475" />
              <mxPoint x="1500" y="475" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============ EDGES — ASYNC SIDE EFFECTS ============ -->
        <mxCell id="e6" value="consume cdt/credito/pago.eventos" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="sb_broker" target="bg_fraud">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="940" y="540" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e7" value="consume todos los eventos&#10;(fan-out · sin estado)" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="sb_broker" target="bg_notif">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="WORM append&#10;sin contención" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="c_fraud" target="sb_audit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ EDGE CLAVE — LOOP-BACK ============ -->
        <mxCell id="e9" value="congelarCDT(id, motivo)  [sync, idempotente]&#10;sin lock distribuido — converge por row-level lock + WHERE status IN (...)" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF;strokeColor=#CC0000;fontColor=#CC0000;strokeWidth=2;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0" edge="1" parent="1" source="c_fraud" target="c_cdtsvc">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="940" y="510" />
              <mxPoint x="220" y="510" />
              <mxPoint x="220" y="240" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="loop_label" value="bucle de retroalimentación&#10;Fase 1 → broker → Fase 4 → Fase 1" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=3;fontColor=#CC0000" vertex="1" parent="1">
          <mxGeometry x="60" y="450" width="200" height="40" as="geometry" />
        </mxCell>

        <!-- Footnote -->
        <mxCell id="footnote" value="Historia de concurrencia: el cliente recibe 202 Accepted en cuanto la TX ACID en AlmacenCDTXPais commit-ea (CDT + outbox en la misma transacción, &lt; 800 ms — ASR-1). El evento al broker es fire-and-forget (flecha punteada): si el broker está caído, el outbox dispatcher reintentará. Mucho después, en otro hilo, DetectorFraude consume el evento y — si ve anomalía — cierra el bucle con la flecha roja: una llamada SÍNCRONA a CDTXPais.congelarCDT() que entra de vuelta al Request Pool. Esa puerta interna comparte BD con abrirCDT, pero los dos mecanismos vistos (row-level lock + idempotencia del UPDATE WHERE status IN ...) hacen que reintentos o duplicados converjan al mismo estado terminal sin necesidad de coordinación distribuida (ASR-8 ≤ 30 min)." style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#444444" vertex="1" parent="1">
          <mxGeometry x="40" y="860" width="1620" height="180" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
