  <diagram name="Fases 1 y 4 combinadas" id="fase14">
    <mxGraphModel dx="2400" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Fases 1 + 4 — Apertura del CDT (sync) y Efectos secundarios (async)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1620" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="El write path responde &lt; 800 ms (ASR-1). El evento al broker es fire-and-forget; los efectos secundarios viajan en hilos background. Cuando DetectorFraude detecta anomalía cierra el bucle llamando síncronamente a CDTXPais.congelarCDT() — idempotente, sin lock distribuido (ASR-8 ≤ 30 min)." style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#666666" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1620" height="40" as="geometry" />
        </mxCell>

        <mxCell id="sec_sync" value="▼  Camino síncrono (Fase 1) — el cliente espera bloqueado" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#444444" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="600" height="20" as="geometry" />
        </mxCell>

        <!-- Cliente -->
