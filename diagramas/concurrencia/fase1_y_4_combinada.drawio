        <mxCell id="c_borde_note" value="Pool acotado.&#10;Rate-limit WAF + ApiGateway&#10;por clienteId.&#10;Frena el pico antes&#10;de LineaVerde." style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#666666" vertex="1" parent="t_borde">
          <mxGeometry x="10" y="240" width="200" height="120" as="geometry" />
