        <mxCell id="e5" value="Compare-and-Swap + TTL refresh" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="bg_cache" target="sb_redis">
