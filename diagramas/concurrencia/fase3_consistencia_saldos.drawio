        <mxCell id="e6" value="SET eligibility (atómico)" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="bg_elig" target="sb_redis">
