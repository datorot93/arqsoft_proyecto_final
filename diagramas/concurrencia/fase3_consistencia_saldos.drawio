          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" value="GET (lock-free) sub-ms" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="t_req" target="sb_redis">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="footnote" value="Historia de concurrencia: el redo log del core es fuente única de verdad ordenada. ChangeDataCapture la convierte en stream y el particionamiento por clienteId garantiza que las actualizaciones de la misma cuenta se aplican en orden. CAS sobre el cache hace cada update atómico. Las lecturas entran por el Borde (rate-limit), pasan al pool de LineaVerde y consultan el cache lock-free — NO tocan al core, lo que las desacopla de la ventana de mantenimiento (ASR-6)." style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#444444" vertex="1" parent="1">
          <mxGeometry x="40" y="690" width="1620" height="80" as="geometry" />
        </mxCell>

