          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="congelarCDT(id) [sync]&#10;si detecta anomalía" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF;strokeColor=#CC0000;fontColor=#CC0000" edge="1" parent="1" source="bg_fraud" target="t_cdt">
