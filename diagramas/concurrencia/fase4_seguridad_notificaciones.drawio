          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="consume todos los eventos&#10;(fan-out)" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;fontSize=10;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="sb_broker" target="bg_notif">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="footnote" value="Historia de concurrencia: ningún side-effect bloquea el write path síncrono de Fase 1. DetectorFraude consume eventos en su propio hilo background y mantiene estado local por cliente (sticky a la partición). Cuando detecta anomalía llama síncronamente a CDTXPais.congelarCDT() — un método idempotente que tolera reintentos. Notificaciones es stateless y hace fan-out a múltiples canales en paralelo." style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#444444" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="1420" height="80" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
